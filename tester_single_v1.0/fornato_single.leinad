CORRESPONDE_A-3;ELEMENTO_A_PREGUNTAR-3
CORRESPONDE_A-4;ELEMENTO_A_PREGUNTAR-4
CORRESPONDE_A-5;ELEMENTO_A_PREGUNTAR-5
...
CORRESPONDE_A-NUM_PAREJAS ; ELEMENTO_A_PREGUNTAR-NUM_PAREJAS
