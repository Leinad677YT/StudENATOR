NUM_OPCIONES_A_DAR                     // [1,9] 
NUM_PAREJAS                            // > NUM_OPCIONES_A_DAR, si usas un editor que marque lineas, haz `linea_final_vacia - 5` al terminar de escribirlos

CORRESPONDE_A-1;ELEMENTO_A_PREGUNTAR-1 // ni los antecedentes ni los consecuentes deben superar 120 caracteres
